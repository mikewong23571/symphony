# Local development environment for `make dev`.
# Priority order:
# 1. Explicit environment variables when invoking the command
# 2. `.env.local`
# 3. `.env`
# 4. Defaults in `scripts/dev/start.sh`
#
# Copy this file to `.env` and adjust values as needed.

DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_ALLOWED_HOSTS=*
LINEAR_API_KEY=your-linear-api-key

# Dev mode:
# - `local` binds api/runtime/web to 127.0.0.1
# - `lan` binds api/runtime/web to 0.0.0.0
DEV_MODE=local

# Listener ports used by `make dev`.
API_PORT=8000
WEB_PORT=4200
RUNTIME_PORT=9000

# Runtime working directory prepared by `scripts/dev/start.sh`.
RUNTIME_ROOT=./.runtime/dev

# Workflow template copied into `${RUNTIME_ROOT}/WORKFLOW.md` on startup.
WORKFLOW_TEMPLATE_PATH=./examples/WORKFLOW.dev.md

# Shared runtime paths consumed by Django and orchestrator.
SYMPHONY_WORKFLOW_PATH=./.runtime/dev/WORKFLOW.md
SYMPHONY_RUNTIME_SNAPSHOT_PATH=./.runtime/dev/snapshot.json
SYMPHONY_RUNTIME_REFRESH_REQUEST_PATH=./.runtime/dev/refresh-request.json
SYMPHONY_RUNTIME_RECOVERY_PATH=./.runtime/dev/recovery.json
